@app.route('/api/history', methods=['GET'])
def api_history():
    history = []
    with state_lock:
        for fid, session in active_sessions.items():
            name = known_face_names.get(fid, f"Person {fid}")
            login_dt = datetime.utcfromtimestamp(session["login"]).strftime("%Y-%m-%d %H:%M:%S")
            history.append({
                "id": fid,
                "name": name,
                "status": "Active",
                "login_time": login_dt,
                "logout_time": "Present",
                "duration": "Counting..."
            })
    for log in reversed(activity_logs):
        fid = log["face_id"]
        name = known_face_names.get(fid, f"Person {fid}")
        dur = log["duration_seconds"]
        dur_str = f"{dur}s" if dur < 60 else f"{dur//60}m {dur%60}s"
        history.append({
            "id": fid,
            "name": name,
            "status": "Logged Out",
            "login_time": log["login_time"],
            "logout_time": log["logout_time"],
            "duration": dur_str
        })
    return jsonify(history)

@app.route('/api/history', methods=['DELETE'])
def delete_history():
    data = request.json
    face_id = data.get('id')
    login_time = data.get('login_time')
    
    with db_lock:
        global activity_logs
        if face_id == 'all':
            activity_logs = []
            save_db()
            return jsonify({"success": True})
        elif face_id is not None and login_time is not None:
            original_len = len(activity_logs)
            activity_logs = [log for log in activity_logs if not (log['face_id'] == face_id and log['login_time'] == login_time)]
            if len(activity_logs) < original_len:
                save_db()
                return jsonify({"success": True})
            return jsonify({"success": False, "error": "Log not found"}), 404
        return jsonify({"success": False, "error": "Invalid request"}), 400

@app.route('/api/settings', methods=['GET', 'POST'])
def api_settings():
    global model
    if request.method == 'POST':
        data = request.json
        new_model_name = data.get("yolo_model", config.get("yolo_model", "yolo26n.pt"))
        if new_model_name != config.get("yolo_model"):
            print(f"Switching YOLO model to {new_model_name}...")
            with model_lock:
                model = YOLO(new_model_name)
            config["yolo_model"] = new_model_name
            
        config["conf"] = float(data.get("conf", 0.50))
        config["imgsz"] = int(data.get("imgsz", 640))
        config["face_tolerance"] = float(data.get("face_tolerance", 0.55))
        config["draw_boxes"] = bool(data.get("draw_boxes", True))
        config["show_range"] = bool(data.get("show_range", True))
        config["camera_source"] = data.get("camera_source", config.get("camera_source", "local"))
        config["stream_url"] = data.get("stream_url", config.get("stream_url", "rtsp://192.168.100.59:8554/lsc_camera"))
        return jsonify({"success": True})
    return jsonify(config)

@app.route('/update_face', methods=['POST'])
def update_face():
    data = request.json
    old_id = int(data.get('old_id', data.get('id')))
    new_name = data.get('name')
    new_id_str = data.get('new_id')
    
    with db_lock:
        if old_id in known_face_ids:
            if new_id_str is not None and str(new_id_str).strip() != "" and int(new_id_str) != old_id:
                new_id = int(new_id_str)
                if new_id in known_face_ids:
                    return jsonify({"success": False, "error": f"ID #{new_id} is already in use."}), 400
                
                idx = known_face_ids.index(old_id)
                known_face_ids[idx] = new_id
                
                known_face_names[new_id] = new_name
                del known_face_names[old_id]
                
                if old_id in known_face_images:
                    known_face_images[new_id] = known_face_images.pop(old_id)
                if old_id in access_rules:
                    access_rules[new_id] = access_rules.pop(old_id)
                if old_id in era_rules:
                    era_rules[new_id] = era_rules.pop(old_id)
                for space in custom_spaces.values():
                    if old_id in space["rules"]:
                        space["rules"][new_id] = space["rules"].pop(old_id)
                    
                with state_lock:
                    if old_id in clothing_profiles:
                        clothing_profiles[new_id] = clothing_profiles.pop(old_id)
                    if old_id in active_sessions:
                        active_sessions[new_id] = active_sessions.pop(old_id)
                    if old_id in door_zone_active:
                        door_zone_active.remove(old_id)
                        door_zone_active.add(new_id)
                    for k, v in list(track_to_face_id.items()):
                        if v == old_id:
                            track_to_face_id[k] = new_id
                            
                global next_face_id
                if new_id >= next_face_id:
                    next_face_id = new_id + 1
            else:
                known_face_names[old_id] = new_name
                
            save_db()
            return jsonify({"success": True})
    return jsonify({"success": False, "error": "ID not found"}), 404

@app.route('/api/rules', methods=['GET', 'POST'])
def api_rules():
    global access_rules
    if request.method == 'GET':
        with state_lock:
            return jsonify(access_rules)
    else:
        data = request.json
        fid = data.get('id')
        role = data.get('role')
        if fid is not None and role:
            with db_lock:
                access_rules[fid] = role
                save_db()
            return jsonify({"success": True})
        return jsonify({"success": False})

