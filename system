    <script>
        lucide.createIcons();

        // --- Theme Management ---
        function toggleTheme() {
            document.body.classList.toggle('light-mode');
            const isLight = document.body.classList.contains('light-mode');
            document.getElementById('theme-icon').setAttribute('data-lucide', isLight ? 'moon' : 'sun');
            lucide.createIcons();
        }

        // --- Navigation ---
        function switchView(viewId) {
            document.querySelectorAll('.view-section').forEach(el => el.classList.add('hidden'));
            document.getElementById('view-' + viewId).classList.remove('hidden');
            
            document.querySelectorAll('.nav-btn').forEach(el => {
                el.classList.remove('active');
                el.classList.add('opacity-70');
            });
            const activeBtn = document.getElementById('nav-' + viewId);
            activeBtn.classList.add('active');
            activeBtn.classList.remove('opacity-70');
            
            if(viewId === 'settings') loadSettings();
            if(viewId === 'custom') loadCustomRules();
            if(viewId === 'ai') loadAiSettings();
        }

        // --- Clock & Terminal ---
        setInterval(() => {
            const now = new Date().toLocaleTimeString();
            document.getElementById('clock').innerText = now;
            document.getElementById('term-time').innerText = `[${now}]`;
        }, 1000);

        let termLogs = [];
        let lastLogsJSON = "";
        
        function renderTerminal() {
            document.getElementById('terminal-logs').innerHTML = termLogs.map(l => `
                <div class="opacity-80 hover:opacity-100 transition-opacity">
                    ${l}
                </div>
            `).join('');
        }
        renderTerminal();

        function runHeuristics(btn) {
            btn.innerText = "Scanning...";
            btn.classList.add('animate-pulse');
            setTimeout(() => {
                btn.innerText = "Run Behavioral Heuristics";
                btn.classList.remove('animate-pulse');
                termLogs.push("> BEHAVIORAL SCAN COMPLETE. ALL CLEAR.");
                renderTerminal();
            }, 1500);
        }

        // --- Global Data Fetching ---
        let allFaces = [];

        async function fetchStats() {
            if (document.getElementById('view-dashboard').classList.contains('hidden')) return;
            try {
                const res = await fetch('/stats');
                const data = await res.json();
                document.getElementById('stat-range').innerText = data.currently_in_range;
                document.getElementById('stat-faces').innerText = data.total_known_faces;
                document.getElementById('stat-tracks').innerText = data.total_yolo_tracks;
                
                const newLogsJSON = JSON.stringify(data.logs);
                if (lastLogsJSON !== newLogsJSON) {
                    termLogs = data.logs;
                    lastLogsJSON = newLogsJSON;
                    renderTerminal();
                }
            } catch(e) {}
        }
