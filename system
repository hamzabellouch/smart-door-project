        async function editFace(id, currentName) {
            const newName = prompt(`Enter a new name for Person #${id}:`, currentName);
            if (newName !== null) {
                const newId = prompt(`Enter a new ID for ${newName.trim()} (leave blank to keep #${id}):`, id);
                if (newId !== null) {
                    const res = await fetch('/update_face', {
                        method: 'POST',
