# --- Advanced ReID System ---
clothing_profiles = {}

def get_clothing_hist(rgb_img, x1, y1, x2, y2):
    crop = rgb_img[max(0, y1):max(0, y2), max(0, x1):max(0, x2)]
    if crop.size == 0:
        return None
    hsv = cv2.cvtColor(crop, cv2.COLOR_RGB2HSV)
    hist = cv2.calcHist([hsv], [0, 1], None, [50, 60], [0, 180, 0, 256])
    cv2.normalize(hist, hist, 0, 1, cv2.NORM_MINMAX)
    return hist

# --- Background Processing Setup ---
face_processing_queue = queue.Queue()
processing_track_ids = set()

def process_faces_in_background():
    global next_face_id
    while True:
        item = face_processing_queue.get()
        if item is None:
            break
        
        track_id, person_crop = item
        try:
            # dlib_lock serializes all face_recognition calls — dlib is NOT thread-safe
            with dlib_lock:
                face_locations = face_recognition.face_locations(person_crop, model="hog")
                if face_locations:
                    face_encoding = face_recognition.face_encodings(person_crop, face_locations, num_jitters=1)[0]
                else:
                    face_encoding = None

            if face_encoding is not None:
                with db_lock:
                    if len(known_face_encodings) > 0:
                        with dlib_lock:
                            face_distances = face_recognition.face_distance(known_face_encodings, face_encoding)
                        best_match_index = np.argmin(face_distances)
                        
                        if face_distances[best_match_index] < config["face_tolerance"]:
                            face_id = known_face_ids[best_match_index]
                            with state_lock:
                                name = known_face_names.get(face_id, f"Person {face_id}")
                                log_event(f"> IDENTITY CONFIRMED: {name}")
                        else:
                            face_id = next_face_id
                            known_face_encodings.append(face_encoding)
                            known_face_ids.append(face_id)
                            known_face_names[face_id] = f"Person {face_id}"
                            
                            _, buffer = cv2.imencode('.jpg', cv2.cvtColor(person_crop, cv2.COLOR_RGB2BGR))
                            known_face_images[face_id] = base64.b64encode(buffer).decode('utf-8')
                            
                            with state_lock:
                                log_event(f"> NEW PERSON REGISTERED: ID #{face_id}")
                            
                            next_face_id += 1
                            save_db()
                    else:
                        face_id = next_face_id
                        known_face_encodings.append(face_encoding)
                        known_face_ids.append(face_id)
                        known_face_names[face_id] = f"Person {face_id}"
                        
                        _, buffer = cv2.imencode('.jpg', cv2.cvtColor(person_crop, cv2.COLOR_RGB2BGR))
                        known_face_images[face_id] = base64.b64encode(buffer).decode('utf-8')
                        
                        with state_lock:
                            log_event(f"> NEW PERSON REGISTERED: ID #{face_id}")
                        
                        next_face_id += 1
                        save_db()
                
                track_to_face_id[track_id] = face_id
        except Exception as e:
            print(f"Error processing face: {e}")
        finally:
            if track_id not in track_to_face_id and track_id in processing_track_ids:
                processing_track_ids.remove(track_id)
            face_processing_queue.task_done()

# Only 1 worker thread — dlib is NOT thread-safe, multiple threads cause segfaults
threading.Thread(target=process_faces_in_background, daemon=True).start()

latest_processed_frame = None
camera_running = False

def camera_loop():
    global latest_processed_frame, camera_running
    
    camera_running = True
    current_source = None
    cap = None
    
    while camera_running:
        expected_source = config.get("camera_source", "local")
        stream_url = config.get("stream_url", "rtsp://192.168.100.59:8554/lsc_camera")
        
        # Auto-correct go2rtc HTML URLs to direct stream endpoints for OpenCV
        if "stream.html?src=" in stream_url:
            stream_url = stream_url.replace("stream.html?src=", "api/stream.mp4?src=")

        if current_source != expected_source or cap is None or not cap.isOpened():
            if cap is not None:
                cap.release()
            current_source = expected_source
            source_val = 0 if current_source == "local" else stream_url
            print(f"Connecting to camera: {source_val}")
            
            if current_source == "stream":
                # Increase robustness for network streams
                os.environ["OPENCV_FFMPEG_CAPTURE_OPTIONS"] = "rtsp_transport;tcp|analyzeduration;500000|probesize;5000000"
                cap = cv2.VideoCapture(source_val, cv2.CAP_FFMPEG)
            else:
                cap = cv2.VideoCapture(source_val)
                
            if not cap.isOpened():
                print(f"Error: Could not open camera {source_val}")
                time.sleep(2)
                continue
                
        success, frame = cap.read()
        if not success:
            print("Failed to read frame, attempting reconnect...")
            cap.release()
            cap = None
            time.sleep(1)
            continue
            
        rgb_frame = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
        with model_lock:
            results = model.track(frame, persist=True, conf=config["conf"], imgsz=config["imgsz"], classes=[0], verbose=False, device="cpu")
        
        # Always compute h, w — used for door zone logic regardless of show_range
        h, w = frame.shape[:2]
        
        if config["show_range"]:
            # All space Target Range
            cv2.rectangle(frame, (0, 0), (w, h), (56, 189, 248), 4)
            cv2.putText(frame, "Target Range (All Space)", (10, 30), cv2.FONT_HERSHEY_SIMPLEX, 0.6, (56, 189, 248), 2)
            
            # Door Zone at the bottom (centered rectangle)
            door_x1_hud, door_y1_hud = w // 4, h - int(h * 0.25)
            door_x2_hud, door_y2_hud = 3 * w // 4, h
            cv2.rectangle(frame, (door_x1_hud, door_y1_hud), (door_x2_hud, door_y2_hud), (34, 197, 94), 2)
            cv2.putText(frame, "Door Zone", (door_x1_hud, door_y1_hud - 10), cv2.FONT_HERSHEY_SIMPLEX, 0.6, (34, 197, 94), 2)

        people_in_range = 0

        if results[0].boxes.id is not None:
            boxes = results[0].boxes.xyxy.cpu().numpy()
            yolo_track_ids = results[0].boxes.id.cpu().numpy()
            
            has_keypoints = hasattr(results[0], 'keypoints') and results[0].keypoints is not None
            keypoints_data = results[0].keypoints.xy.cpu().numpy() if has_keypoints else None

            for i, (box, track_id) in enumerate(zip(boxes, yolo_track_ids)):
                x1, y1, x2, y2 = map(int, box)
                cx = (x1 + x2) // 2
                cy = (y1 + y2) // 2
                
                # Hand Raise Detection
                is_hand_raised = False
                if keypoints_data is not None and len(keypoints_data) > i:
                    kpts = keypoints_data[i]
                    if len(kpts) >= 11:
                        nose_y = kpts[0][1]
                        l_wrist_y = kpts[9][1]
                        r_wrist_y = kpts[10][1]
                        if (l_wrist_y > 0 and l_wrist_y < nose_y) or (r_wrist_y > 0 and r_wrist_y < nose_y):
                            is_hand_raised = True
                            
                current_time = time.time()
                if is_hand_raised:
                    hand_last_seen[track_id] = current_time
                    if track_id not in hand_raised_start:
                        hand_raised_start[track_id] = current_time
                    if current_time - hand_raised_start[track_id] >= 3:
                        if not color_is_red.get(track_id, False):
                            with state_lock:
                                log_event(f"> ATTENTION: HAND RAISE DETECTED (ID {track_id})")
                        color_is_red[track_id] = True
                else:
                    last_seen = hand_last_seen.get(track_id, 0)
                    if current_time - last_seen > 1.0:
                        hand_raised_start.pop(track_id, None)
                        color_is_red[track_id] = False

                # Target Range is all space, so we detect everyone in the frame
                people_in_range += 1
                
                # --- Face scanning/recognition always runs, independent of draw_boxes ---
                if track_id not in tracked_ids:
                    tracked_ids.add(track_id)
                    stats["total_yolo_tracks"] += 1
                    with state_lock:
                        log_event(f"> NEW TARGET ACQUIRED (YOLO ID: {track_id})")
                
                display_id = track_to_face_id.get(track_id)
                
                # Clothing-based Re-ID
                if display_id is None:
                    current_hist = get_clothing_hist(rgb_frame, x1, y1, x2, y2)
                    with state_lock:
                        profiles_copy = clothing_profiles.copy()
                    if current_hist is not None and len(profiles_copy) > 0:
                        best_match = None
                        best_score = 0.65
                        for fid, hist in profiles_copy.items():
                            if hist is not None:
                                score = cv2.compareHist(current_hist, hist, cv2.HISTCMP_CORREL)
                                if score > best_score:
                                    best_score = score
                                    best_match = fid
                        if best_match is not None:
                            track_to_face_id[track_id] = best_match
                            display_id = best_match
                
                # Door zone logic always runs
                if display_id is not None:
                    with state_lock:
                        clothing_profiles[display_id] = get_clothing_hist(rgb_frame, x1, y1, x2, y2)
                    
                    dz_x1, dz_y1 = w // 4, h - int(h * 0.25)
                    dz_x2, dz_y2 = 3 * w // 4, h
                    if dz_x1 < cx < dz_x2 and dz_y1 < cy < dz_y2:
                        if display_id not in door_zone_active:
                            door_zone_active.add(display_id)
                            rule = access_rules.get(display_id, "Not Allowed")
                            with state_lock:
                                name = known_face_names.get(display_id, f"Person {display_id}")
                                if rule == "Allowed":
                                    log_event(f"> ACCESS GRANTED: {name} entered Door Zone.")
                                else:
                                    log_event(f"> ALERT: UNAUTHORIZED PERSON ({name}) in Door Zone!")
                    else:
                        if display_id in door_zone_active:
                            door_zone_active.remove(display_id)
                
                # Queue for face recognition background scan if still unidentified
                if display_id is None and track_id not in processing_track_ids:
                    px1, py1 = max(0, x1 - 20), max(0, y1 - 20)
                    px2, py2 = min(frame.shape[1], x2 + 20), min(frame.shape[0], y2 + 20)
                    person_crop = rgb_frame[py1:py2, px1:px2]
                    if person_crop.size > 0:
                        processing_track_ids.add(track_id)
                        face_processing_queue.put((track_id, person_crop.copy()))
                
                # Update active sessions
                if display_id is not None:
                    current_t = time.time()
                    with state_lock:
                        if display_id not in active_sessions:
                            active_sessions[display_id] = {"login": current_t, "last_seen": current_t}
                        else:
                            active_sessions[display_id]["last_seen"] = current_t

                # --- Drawing is separate and optional ---
                if config["draw_boxes"]:
                    cv2.circle(frame, (cx, cy), 4, (56, 189, 248), -1)
                    
                    if display_id is None:
                        display_text = "Scanning..."
                        box_color = (128, 128, 128)
                    else:
                        display_name = known_face_names.get(display_id, f"Person {display_id}")
                        display_text = f"ID: {display_id} | {display_name}"
                        box_color = (255, 191, 56)

                    if color_is_red.get(track_id, False):
                        display_text += " [ATTENTION]"
                        box_color = (0, 0, 255)

                    cv2.rectangle(frame, (x1, y1), (x2, y2), box_color, 2)
                    cv2.putText(frame, display_text, (x1, y1 - 10), cv2.FONT_HERSHEY_SIMPLEX, 0.6, box_color, 2)

        # Handle Session Timeouts
        current_time = time.time()
        expired_ids = []
        logs_to_append = []
        with state_lock:
            for fid, session in list(active_sessions.items()):
                if current_time - session["last_seen"] > 10:
                    login_dt = datetime.utcfromtimestamp(session["login"]).strftime("%Y-%m-%d %H:%M:%S")
                    logout_dt = datetime.utcfromtimestamp(session["last_seen"]).strftime("%Y-%m-%d %H:%M:%S")
                    duration = round(session["last_seen"] - session["login"])
                    
                    if duration >= 2:
                        name = known_face_names.get(fid, f"Person {fid}")
                        log_event(f"> TARGET LOST: {name} ({duration}s)")
                        logs_to_append.append({
                            "face_id": fid,
                            "login_time": login_dt,
                            "logout_time": logout_dt,
                            "duration_seconds": duration
                        })
                    expired_ids.append(fid)
                    
            for fid in expired_ids:
                del active_sessions[fid]
        
        # Persist session logs outside of state_lock to avoid lock-ordering deadlock
        if logs_to_append:
            with db_lock:
                activity_logs.extend(logs_to_append)
                save_db()

        stats["currently_in_range"] = people_in_range
        stats["total_known_faces"] = len(known_face_ids)
        
        ret, buffer = cv2.imencode('.jpg', frame)
        if ret:
            with state_lock:
                latest_processed_frame = buffer.tobytes()
        
        time.sleep(0.01)

# Start background camera thread
threading.Thread(target=camera_loop, daemon=True).start()

def gen_frames():
    while True:
        with state_lock:
            frame_bytes = latest_processed_frame
            
        if frame_bytes is not None:
            yield (b'--frame\r\n'
                   b'Content-Type: image/jpeg\r\n\r\n' + frame_bytes + b'\r\n')
        
        time.sleep(0.03)

