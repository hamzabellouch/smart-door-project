        async function uploadFace() {
            const name = document.getElementById('new_name').value;
            const customId = document.getElementById('new_id').value;
            const fileInput = document.getElementById('new_photo');
            const btn = document.getElementById('btn-upload');
            
            if (!name || !fileInput.files[0]) {
                alert("Please enter a designation and select a bitmap photo.");
                return;
            }
            
            const formData = new FormData();
            formData.append('name', name);
            if (customId) formData.append('custom_id', customId);
            formData.append('file', fileInput.files[0]);
            
            btn.innerText = "Syncing...";
            btn.style.opacity = "0.7";
            
            try {
                const res = await fetch('/upload_face', { method: 'POST', body: formData });
                const data = await res.json();
                if(data.success) {
                    document.getElementById('new_name').value = '';
                    document.getElementById('new_id').value = '';
                    fileInput.value = '';
                    document.getElementById('add-modal').classList.add('hidden');
                    fetchFaces();
                } else {
                    alert("Error: " + data.error);
                }
            } catch(e) {
                alert("Upload failed.");
            }
            btn.innerText = "Confirm Sync";
            btn.style.opacity = "1";
        }

