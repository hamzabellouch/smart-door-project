def delete_face(fid):
    with db_lock:
        if fid in known_face_ids:
            idx = known_face_ids.index(fid)
            known_face_ids.pop(idx)
            known_face_encodings.pop(idx)
            known_face_names.pop(fid, None)
            known_face_images.pop(fid, None)
            access_rules.pop(fid, None)
            era_rules.pop(fid, None)
