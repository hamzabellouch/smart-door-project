@app.route('/upload_face', methods=['POST'])
def upload_face():
    global next_face_id
    name = request.form.get('name', 'Uploaded Person')
    file = request.files.get('file')
    if not file: 
        return jsonify({"success": False, "error": "No image file provided"})
    
    try:
        file_bytes = np.frombuffer(file.read(), np.uint8)
        img = cv2.imdecode(file_bytes, cv2.IMREAD_COLOR)
        rgb_img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)
        
        face_locations = face_recognition.face_locations(rgb_img, model="hog")
        if not face_locations:
            return jsonify({"success": False, "error": "No face detected in the image"})
        
        face_encoding = face_recognition.face_encodings(rgb_img, face_locations, num_jitters=2)[0]
        
        with db_lock:
            custom_id = request.form.get('custom_id')
            if custom_id is not None and custom_id.strip() != "":
                face_id = int(custom_id)
                if face_id in known_face_ids:
                    return jsonify({"success": False, "error": f"ID #{face_id} is already in use by {known_face_names.get(face_id)}."})
                if face_id >= next_face_id:
                    next_face_id = face_id + 1
            else:
                face_id = next_face_id
                next_face_id += 1

            known_face_encodings.append(face_encoding)
            known_face_ids.append(face_id)
            known_face_names[face_id] = name
            
            top, right, bottom, left = face_locations[0]
            top = max(0, top-20)
            bottom = min(rgb_img.shape[0], bottom+20)
            left = max(0, left-20)
            right = min(rgb_img.shape[1], right+20)
            
            face_crop = rgb_img[top:bottom, left:right]
            _, buffer = cv2.imencode('.jpg', cv2.cvtColor(face_crop, cv2.COLOR_RGB2BGR))
            known_face_images[face_id] = base64.b64encode(buffer).decode('utf-8')
            
            save_db()
        return jsonify({"success": True})
    except Exception as e:
        return jsonify({"success": False, "error": str(e)})


