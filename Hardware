#include <Wire.h> 
#include <LiquidCrystal_I2C.h>
#include <Keypad.h>
#include <Servo.h>
#include <IRremote.h>
#include <SPI.h>
#include <MFRC522.h>

// LCD setup
LiquidCrystal_I2C lcd(0x27, 16, 2);

// RFID setup
#define SS_PIN 10
#define RST_PIN 5
MFRC522 mfrc522(SS_PIN, RST_PIN);

// Put your card's UID here if you know it, otherwise the lock will currently open with any card
String allowedUID = "YOUR_CARD_UID_HERE"; 

// Keypad setup
const byte ROWS = 4; 
const byte COLS = 4; 
char keys[ROWS][COLS] = {
  {'1','2','3','A'},
  {'4','5','6','B'},
  {'7','8','9','C'},
  {'*','0','#','D'}
};
byte rowPins[ROWS] = {3, 4, 6, 7};    
byte colPins[COLS] = {8, A0, A2, A3};  

Keypad keypad = Keypad(makeKeymap(keys), rowPins, colPins, ROWS, COLS);

// Setup remaining components
Servo myServo;
const int servoPin = 9;        
const int speakerPin = 1;      // Pin D1 is now free and dedicated to audio
const int IR_RECEIVE_PIN = 2;  
const int sensorPin = A1;      

String password = "2026"; 
String inputString = ""; 
bool isDoorOpen = false;

void setup() {
  // Serial.begin was removed to fully free port 1 for the speaker
  SPI.begin();         
  mfrc522.PCD_Init();   
  
  myServo.attach(servoPin);
  myServo.write(0); 
  pinMode(speakerPin, OUTPUT);
  pinMode(sensorPin, INPUT_PULLUP); 
  
  lcd.begin();          
  lcd.backlight();    
  
  IrReceiver.begin(IR_RECEIVE_PIN); 
  showWelcomeMessage();
}

void loop() {
  // 1. Remote control
  if (IrReceiver.decode()) {
    handleRemoteControl();
    IrReceiver.resume(); 
  }

  // 2. Sensor
  if (digitalRead(sensorPin) == LOW && !isDoorOpen) { 
    openDoor();
  }

  // 3. RFID cards
  if (mfrc522.PICC_IsNewCardPresent() && mfrc522.PICC_ReadCardSerial()) {
    handleRFID();
  }

  // 4. Keypad
  char key = keypad.getKey();
  if (key) {
    tone(speakerPin, 3000, 50); // Slight beep sound when pressing any button
    if (key == '#') {      
      checkPassword();
    } 
    else if (key == '*') {     
      resetInput();
    }
    else {                     
      inputString += key;
      lcd.setCursor(inputString.length() - 1, 1);
      lcd.print("*"); 
    }
  }
}

void handleRFID() {
  String readUID = "";
  for (byte i = 0; i < mfrc522.uid.size; i++) {
    readUID += String(mfrc522.uid.uidByte[i] < 0x10 ? "0" : "");
    readUID += String(mfrc522.uid.uidByte[i], HEX);
    if (i < mfrc522.uid.size - 1) readUID += " ";
  }
  readUID.toUpperCase();

  if (readUID == allowedUID || allowedUID == "YOUR_CARD_UID_HERE") {
    openDoor();
  } else {
    lcd.clear();
    lcd.print("Invalid Card!");
    tone(speakerPin, 500, 1500); // Alarm sound when scanning an invalid card
    delay(2000);
    resetInput();
  }
  mfrc522.PICC_HaltA();
}

void openDoor() {
  if (isDoorOpen) return;
  
  lcd.clear();
  lcd.print("Access Granted!");
  tone(speakerPin, 3000, 400); // Welcome tone when opening the door
  
  for (int pos = 0; pos <= 90; pos += 1) { 
    myServo.write(pos);
    delay(15); 
  }
  
  isDoorOpen = true;

  for (int i = 10; i > 0; i--) {
    lcd.setCursor(0, 1);
    lcd.print("Closing in: ");
    lcd.print(i);
    lcd.print("s  "); 
    tone(speakerPin, 1800, 80); // Ticking sound during the countdown to close
    delay(1000);      
  }
  
  closeDoor(); 
}

void closeDoor() {
  if (!isDoorOpen) return;
  
  lcd.clear();
  lcd.print("Auto Closing...");
  
  for (int pos = 90; pos >= 0; pos -= 1) { 
    myServo.write(pos);
    delay(15); 
  }
  
  isDoorOpen = false;
  tone(speakerPin, 1200, 400); // Door closing confirmation tone
  delay(500);
  resetInput();
}

void checkPassword() {
  if (inputString == password) {
    openDoor();
  } else {
    lcd.clear();
    lcd.print("Wrong Password!");
    tone(speakerPin, 600, 1500); // Long error sound when entering a wrong password
    delay(2000);
    resetInput();
  }
}

void handleRemoteControl() {
  unsigned long command = IrReceiver.decodedIRData.command;
  if (command == 0x0C && !isDoorOpen) { 
    openDoor();
  }
}

void resetInput() {
  inputString = "";
  lcd.clear();
  lcd.print("Enter Password:");
  lcd.setCursor(0, 1);
}

void showWelcomeMessage() {
  lcd.clear();
  lcd.print("  Smart Lock   ");
  lcd.setCursor(0, 1);
  lcd.print("    Ready!     ");
  delay(1000);
  resetInput();
}
